{
  "name": "finapp-mvp-shell",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run src/application/use-cases/__tests__",
    "test:e2e:smoke": "playwright test --project=smoke-mobile e2e/smoke.mobile.spec.ts",
    "test:e2e:recurrence:lifecycle": "playwright test --project=smoke-mobile e2e/recurrence.lifecycle.spec.ts",
    "test:e2e:smoke:fixture": "SMOKE_MODE=fixture playwright test --project=smoke-mobile e2e/smoke.mobile.spec.ts",
    "test:e2e:smoke:fixture:refresh": "SMOKE_MODE=fresh SMOKE_CAPTURE_FIXTURE_PATH=e2e/fixtures/finapp.smoke.fixture.json playwright test --project=smoke-mobile e2e/smoke.mobile.spec.ts",
    "dev:snapshot:capture": "node scripts/dev/localStorageSnapshot.mjs capture",
    "dev:snapshot:restore": "node scripts/dev/localStorageSnapshot.mjs restore",
    "test:e2e:smoke:snapshot": "SMOKE_MODE=snapshot playwright test --project=smoke-mobile e2e/smoke.mobile.spec.ts"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.30.1"
  },
  "devDependencies": {
    "@playwright/test": "^1.53.0",
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "typescript": "^5.6.3",
    "vite": "^5.4.10",
    "vitest": "^4.1.0"
  }
}
